generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  role      String   @default("architect")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects    Project[]
  diaries     Diary[]
  tasks       Task[]
  incomes     Income[]
  expenses    Expense[]
  documents   Document[]
  clients     Client[]
  contracts   Contract[]
  receivables Receivable[]
  debts       Debt[]
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  company   String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects    Project[]
  payments    Income[]
  contracts   Contract[]
  receivables Receivable[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String?
  address     String?
  startDate   DateTime?
  deadline    DateTime?
  status      String    @default("NEW")
  description String?
  budget      Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String?
  client   Client?  @relation(fields: [clientId], references: [id])

  files      ProjectFile[]
  notes      ProjectNote[]
  tasks      Task[]
  incomes    Income[]
  diaryLinks DiaryProject[]
  contracts  Contract[]
}

model ProjectFile {
  id           String   @id @default(cuid())
  name         String
  originalName String
  path         String
  size         Int
  mimeType     String
  createdAt    DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectNote {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Diary {
  id          String   @id @default(cuid())
  date        DateTime
  title       String
  description String?
  workDone    String?
  problems    String?
  decisions   String?
  images      String?
  mood        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects DiaryProject[]
}

model DiaryProject {
  id        String  @id @default(cuid())
  diaryId   String
  projectId String
  diary     Diary   @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([diaryId, projectId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  deadline    DateTime?
  priority    String    @default("MEDIUM")
  status      String    @default("TODO")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
}

model Income {
  id          String   @id @default(cuid())
  date        DateTime
  amount      Float
  description String?
  category    String?
  createdAt   DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  amount      Float
  description String?
  category    String?
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id           String   @id @default(cuid())
  name         String
  originalName String
  path         String
  size         Int
  mimeType     String
  folder       String   @default("OTHER")
  description  String?
  createdAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model Contract {
  id              String   @id @default(cuid())
  contractNumber  String
  title           String
  clientName      String
  clientPhone     String?
  clientEmail     String?
  clientAddress   String?
  clientPassport  String?
  architectName   String
  architectPhone  String?
  architectAddress String?
  projectName     String
  projectAddress  String?
  projectType     String?
  startDate       DateTime?
  endDate         DateTime?
  totalAmount     Float
  advanceAmount   Float?
  workItems       String
  terms           String?
  status          String   @default("DRAFT")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
}


model Receivable {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  description String?
  totalAmount Float
  paidAmount  Float    @default(0)
  dueDate     DateTime?
  status      String   @default("PENDING")  // PENDING | PARTIAL | PAID
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  payments  ReceivablePayment[]
}

model ReceivablePayment {
  id           String   @id @default(cuid())
  amount       Float
  date         DateTime @default(now())
  note         String?
  createdAt    DateTime @default(now())

  receivableId String
  receivable   Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)
}

model Debt {
  id          String   @id @default(cuid())
  creditor    String
  phone       String?
  description String?
  amount      Float
  paidAmount  Float    @default(0)
  borrowedAt  DateTime @default(now())
  dueDate     DateTime?
  status      String   @default("PENDING")  // PENDING | PARTIAL | PAID
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments DebtPayment[]
}

model DebtPayment {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())

  debtId    String
  debt      Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)
}
